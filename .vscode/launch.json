{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        // ── Device runs (safe alongside the PlayStore build) ──────────────────
        // Both are DEBUG, so the buildType adds applicationIdSuffix ".debug":
        //   production-debug -> com.azdhaar.notesapp.debug      (PlayStore is com.azdhaar.notesapp)
        //   rc-debug         -> com.azdhaar.notesapp.rc.debug
        // Different package = installs side-by-side; never overwrites the store app.
        // WARNING: do NOT add "--flavor production" to a profile/release config —
        // those have no ".debug" suffix and would collide with the PlayStore app.
        {
            "name": "notesapp (production · debug)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "toolArgs": ["--flavor", "production"]
        },
        {
            "name": "notesapp (rc · debug)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "toolArgs": ["--flavor", "rc"]
        },

        {
            "name": "notesapp",
            "request": "launch",
            "type": "dart",
            "noDebug": false
        },
        {
            "name": "notesapp (without debug)",
            "request": "launch",
            "type": "dart",
            "noDebug": true
        },
        {
            "name": "notesapp (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "notesapp (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        },
    ]
}
